/* app.wxss */
page {
  background-color: #F8F9FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 按钮样式 */
.btn {
  padding: 24rpx 48rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
  transition: all 0.3s;
}

.btn-primary {
  background: #1989FA;
  color: #FFFFFF;
}

.btn-primary:active {
  background: #0C7CD5;
}

.btn-danger {
  background: #F56C6C;
  color: #FFFFFF;
}

.btn-danger:active {
  background: #F23C3C;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid #1989FA;
  color: #1989FA;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.tag-primary {
  background: rgba(25, 137, 250, 0.1);
  color: #1989FA;
}

.tag-success {
  background: rgba(103, 194, 58, 0.1);
  color: #67C23A;
}

/* 输入框样式 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #606266;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #F5F7FA;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #909399;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #EBEEF5;
  margin: 30rpx 0;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #909399;
}
