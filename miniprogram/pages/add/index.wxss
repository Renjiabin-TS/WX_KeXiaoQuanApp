.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #4a90e2;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.optional {
  color: #999;
  font-weight: normal;
}

.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.picker-text {
  font-size: 30rpx;
  color: #333;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 时间行 */
.time-row {
  display: flex;
  gap: 20rpx;
}

.time-col {
  flex: 1;
}

/* 输入框 */
.input-box {
  padding: 24rpx 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

/* 课时数控制 */
.duration-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin: 40rpx 0;
}

.duration-label {
  font-size: 28rpx;
  color: #333;
}

.duration-value-box {
  width: 100rpx;
  height: 64rpx;
  background: #4a90e2;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.duration-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.duration-unit {
  font-size: 26rpx;
  color: #999;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4a90e2 0%, #6ab2f5 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  margin-top: 20rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn::after {
  border: none;
}
