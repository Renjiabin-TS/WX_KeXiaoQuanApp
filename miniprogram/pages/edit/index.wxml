<view class="container">
  <view class="card">
    <view class="section-title">基本信息</view>
    
    <!-- 日期选择 -->
    <view class="form-item">
      <text class="form-label">授课日期</text>
      <picker 
        mode="date" 
        value="{{date}}" 
        bindchange="onDateChange"
      >
        <view class="picker-value">
          <text>{{date || '请选择日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 时间选择 -->
    <view class="form-row">
      <view class="form-item form-item-half">
        <text class="form-label">开始时间</text>
        <picker mode="time" value="{{startTime}}" bindchange="onStartTimeChange">
          <view class="picker-value">
            <text>{{startTime || '请选择'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      <view class="form-item form-item-half">
        <text class="form-label">结束时间</text>
        <picker mode="time" value="{{endTime}}" bindchange="onEndTimeChange">
          <view class="picker-value">
            <text>{{endTime || '请选择'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 课程类型 -->
    <view class="form-item">
      <text class="form-label">课程类型</text>
      <picker range="{{['一对一', '班课']}}" value="{{lessonType === '一对一' ? 0 : 1}}" bindchange="onTypeChange">
        <view class="picker-value">
          <text>{{lessonType}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 老师姓名 -->
    <view class="form-item">
      <text class="form-label">老师姓名</text>
      <input 
        class="form-input" 
        type="text" 
        placeholder="请输入老师姓名" 
        value="{{teacherName}}"
        bindinput="onTeacherNameInput"
      />
    </view>

    <view class="divider"></view>

    <view class="section-title">课程详情</view>

    <!-- 学生姓名（一对一） -->
    <view class="form-item" wx:if="{{lessonType === '一对一'}}">
      <text class="form-label">学生姓名 <text class="optional-text">（非必填）</text></text>
      <input
        class="form-input"
        type="text"
        placeholder="请输入学生姓名（可选）"
        value="{{studentName}}"
        bindinput="onStudentNameInput"
      />
    </view>

    <!-- 学生数量（班课） -->
    <view class="form-item" wx:if="{{lessonType === '班课'}}">
      <text class="form-label">学生数量 <text class="optional-text">（非必填）</text></text>
      <input
        class="form-input"
        type="number"
        placeholder="请输入学生数量（可选）"
        value="{{studentCount}}"
        bindinput="onStudentCountInput"
      />
    </view>

    <!-- 课时计算 -->
    <view class="duration-display">
      <view class="duration-label">课时时长</view>
      <view class="duration-value">{{duration}}课时</view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button class="btn btn-primary btn-block" bindtap="saveLesson">保存修改</button>
  </view>
</view>
