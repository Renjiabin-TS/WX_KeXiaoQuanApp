.help-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 区块 */
.section {
  background-color: #ffffff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #303133;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #667eea;
}

/* 常见问题 */
.faq-item {
  border-bottom: 1rpx solid #ebeef5;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  cursor: pointer;
}

.question-text {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
}

.arrow-icon {
  font-size: 20rpx;
  color: #909399;
  margin-left: 20rpx;
}

.faq-answer {
  padding: 0 0 24rpx 0;
  font-size: 26rpx;
  color: #606266;
  line-height: 1.6;
}

/* 使用指南 */
.guide-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.guide-item:last-child {
  margin-bottom: 0;
}

.guide-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 80rpx;
  text-align: center;
}

.guide-content {
  flex: 1;
}

.guide-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #303133;
  margin-bottom: 10rpx;
}

.guide-desc {
  font-size: 26rpx;
  color: #909399;
  line-height: 1.5;
}

/* 反馈表单 */
.feedback-form {
  padding: 0 10rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #dcdfe6;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #606266;
  transition: all 0.3s;
}

.type-option.active {
  border-color: #667eea;
  background-color: #ecf5ff;
  color: #667eea;
  font-weight: 500;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #909399;
  margin-top: 10rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 8rpx;
  border: none;
  margin-top: 20rpx;
}

/* 联系方式 */
.contact-section {
  background-color: #ffffff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.contact-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #303133;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #667eea;
}

.contact-info {
  padding: 0 10rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #606266;
  flex: 1;
}
