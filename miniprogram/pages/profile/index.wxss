/* pages/profile/index.wxss */

/* ==================== 通用样式 ==================== */
page {
  background: #F7F7F7;
}

.container {
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* ==================== 未登录状态 ==================== */
.not-logged-container {
  padding: 0 24rpx;
}

.avatar-section {
  text-align: center;
  padding: 80rpx 0 60rpx;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  background: #E5E5E5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 80rpx;
  color: #999;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #666666;
}

.login-actions {
  padding: 40rpx 24rpx;
  text-align: center;
}

.login-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.login-divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
  gap: 24rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E5E5E5;
}

.divider-text {
  font-size: 24rpx;
  color: #999999;
}

.feature-list {
  margin-top: 40rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.feature-info {
  flex: 1;
}

.feature-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999999;
}

.feature-lock {
  font-size: 32rpx;
  opacity: 0.5;
}

/* ==================== 已登录状态 ==================== */
.logged-container {
  padding: 0 24rpx;
}

.user-header {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
}

.user-avatar-btn {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: 24rpx;
  padding: 0;
  border: none;
  background: transparent;
}

.user-avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #F5F5F5;
}

.avatar-edit-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #FFFFFF;
  border: 2rpx solid #FFFFFF;
}

.user-info {
  flex: 1;
}

.user-name-input {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  border: none;
  padding: 0;
}

.user-status {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.user-status.unverified {
  color: #FF9500;
}

.user-status.verified {
  color: #07C160;
}

.status-icon {
  margin-right: 8rpx;
}

/* ==================== 提示卡片 ==================== */
.tip-card {
  display: flex;
  align-items: flex-start;
  background: #FFF8E6;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.tip-card.warning {
  background: #FFF8E6;
  border: 1rpx solid #FFE58F;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.tip-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

/* ==================== 验证按钮区域 ==================== */
.verify-btn-section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

/* ==================== 邮箱验证弹窗表单 ==================== */
.verify-form {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  border: none;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.code-wrapper {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  flex: 0 0 auto;
  padding: 0 24rpx;
  font-size: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  white-space: nowrap;
}

.form-hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* ==================== 设置列表 ==================== */
.settings-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.list-title {
  font-size: 24rpx;
  color: #999999;
  padding: 24rpx 0;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.list-item:active {
  background: #F5F5F5;
}

.list-divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 -24rpx;
}

.item-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.item-label {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.item-desc {
  font-size: 22rpx;
  color: #999999;
  margin-left: 8rpx;
}

.item-value {
  font-size: 24rpx;
  color: #999999;
  margin-right: 8rpx;
}

.item-arrow {
  font-size: 32rpx;
  color: #C0C4CC;
}

/* ==================== 按钮样式 ==================== */
.btn {
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background: #07C160;
  color: #FFFFFF;
}

.btn-outline {
  background: #FFFFFF;
  border: 1rpx solid #E5E5E5;
  color: #333333;
}

.btn-danger {
  border-color: #FF4D4F;
  color: #FF4D4F;
}

.btn-large {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
}

.btn-block {
  width: 100%;
  height: 88rpx;
}

.logout-section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

/* ==================== 版本信息 ==================== */
.version-info {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #C0C4CC;
}

/* ==================== 弹窗样式 ==================== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 640rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  z-index: 1;
  animation: modalSlideUp 0.3s ease;
}

@keyframes modalSlideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  color: #999999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 32rpx 24rpx;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #F5F5F5;
}

.modal-footer .btn {
  flex: 1;
  height: 88rpx;
}

/* ==================== 底部导航 ==================== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #E5E5E5;
  z-index: 100;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 28rpx;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #999999;
}

.nav-item.active .nav-text {
  color: #07C160;
  font-weight: 500;
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  height: constant(safe-area-inset-bottom);
}

/* ==================== 免责弹窗样式 ==================== */
.disclaimer-modal {
  width: 680rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.disclaimer-body {
  flex: 1;
  padding: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.disclaimer-scroll {
  flex: 1;
  max-height: 50vh;
  margin-bottom: 24rpx;
}

.disclaimer-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.disclaimer-checkbox {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #DCDFE6;
  border-radius: 4rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #07C160;
  border-color: #07C160;
}

.checkbox.checked text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
}

.checkbox-label {
  font-size: 26rpx;
  color: #333333;
}

.modal-footer .btn[disabled] {
  background: #C8C8C8;
  color: #FFFFFF;
}
