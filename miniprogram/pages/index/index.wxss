/* pages/index/index.wxss */

.stats-card {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stats-box {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.weekly-box {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.monthly-box {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  box-shadow: 0 4rpx 12rpx rgba(245, 87, 108, 0.3);
}

.stats-title {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-bottom: 20rpx;
  opacity: 0.9;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 10rpx 0;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
  margin-top: 10rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #303133;
}

.add-btn {
  color: #1989FA;
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  border: 1rpx solid #1989FA;
  border-radius: 4rpx;
}

.lesson-list {
  max-height: 800rpx;
  overflow-y: auto;
}

.lesson-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EBEEF5;
}

.lesson-item:last-child {
  border-bottom: none;
}

.lesson-left {
  flex: 1;
}

.lesson-date {
  font-size: 28rpx;
  font-weight: bold;
  color: #303133;
  margin-bottom: 12rpx;
}

.lesson-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.lesson-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.lesson-tag.tag-green {
  background: rgba(103, 194, 58, 0.1);
  color: #67C23A;
}

.lesson-tag.tag-blue {
  background: rgba(25, 137, 250, 0.1);
  color: #1989FA;
}

.lesson-time {
  font-size: 24rpx;
  color: #606266;
}

.lesson-student {
  font-size: 24rpx;
  color: #909399;
}

.lesson-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.lesson-duration {
  font-size: 32rpx;
  font-weight: bold;
  color: #1989FA;
}

.lesson-delete {
  padding: 8rpx;
  color: #F56C6C;
  font-size: 36rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #C0C4CC;
  margin-top: 16rpx;
}

/* 删除验证弹窗 */
.verify-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.verify-content {
  background: #FFFFFF;
  padding: 60rpx 40rpx;
  border-radius: 16rpx;
  width: 600rpx;
}

.verify-title {
  font-size: 32rpx;
  text-align: center;
  margin-bottom: 50rpx;
  color: #303133;
  font-weight: bold;
}

/* 滑动解锁容器 */
.slide-container {
  position: relative;
  width: 100%;
  height: 100rpx;
  background: #F0F2F5;
  border-radius: 50rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  touch-action: none;
  user-select: none;
  -webkit-user-select: none;
  -webkit-touch-callout: none;
}

/* 滑动轨道 */
.slide-track {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  background: #E4E7ED;
  overflow: hidden;
}

/* 滑动进度条 */
.slide-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 0;
  background: linear-gradient(90deg, #409EFF 0%, #66B1FF 100%);
  transition: none;
  will-change: width;
  transform: translateZ(0);
}

/* 滑动按钮 */
.slide-btn {
  position: absolute;
  top: 10rpx;
  left: 0;
  width: 80rpx;
  height: 80rpx;
  background: #409EFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.4);
  transition: none;
  will-change: left;
  transform: translateZ(0);
}

.slide-icon {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: bold;
}

/* 滑动文字 */
.slide-text {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #909399;
  font-size: 28rpx;
  pointer-events: none;
  transition: opacity 0.15s ease-out;
}

.slide-text.hide {
  opacity: 0;
}

.verify-cancel {
  text-align: center;
  color: #909399;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #EBEEF5;
  margin-top: 20rpx;
}

/* ==================== 免责弹窗样式 ==================== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 680rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  z-index: 1;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-body {
  padding: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #F5F5F5;
}

.modal-footer .btn {
  flex: 1;
  height: 88rpx;
}

.modal-footer .btn[disabled] {
  background: #C8C8C8;
  color: #FFFFFF;
}

.disclaimer-modal {
  width: 680rpx;
}

.disclaimer-body {
  flex: 1;
  padding: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.disclaimer-scroll {
  flex: 1;
  max-height: 50vh;
  margin-bottom: 24rpx;
}

.disclaimer-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.disclaimer-checkbox {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #DCDFE6;
  border-radius: 4rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #07C160;
  border-color: #07C160;
}

.checkbox.checked text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
}

.checkbox-label {
  font-size: 26rpx;
  color: #333333;
}

.btn {
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #07C160;
  color: #FFFFFF;
}

.btn-outline {
  background: #FFFFFF;
  border: 1rpx solid #E5E5E5;
  color: #333333;
}
